# Base de datos
# - Local dev: DATABASE_URL="file:../dev.db"
# - PROD recomendado (state aislado): DATABASE_URL="file:/opt/hunter/state/dev.db"
DATABASE_URL="file:../dev.db"

# State paths (opcional, recomendado en PROD)
HUNTER_STATE_DIR="/opt/hunter/state"
HUNTER_STATE_DB_PATH="/opt/hunter/state/dev.db"
HUNTER_STATE_UPLOADS_PATH="/opt/hunter/state/uploads"

# Backend
PORT=4001
JWT_SECRET=super-secret-key

# OpenAI (opcional, se puede cargar desde la UI)
OPENAI_API_KEY=
